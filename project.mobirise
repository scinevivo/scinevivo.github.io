        {
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".row-links": {
              "width": "100%",
              "justify-content": "center"
            },
            ".social-row": {
              "width": "100%",
              "justify-content": "center"
            },
            ".media-container-row": {
              "flex-direction": "column",
              "justify-content": "center",
              "align-items": "center",
              ".foot-menu": {
                "list-style": "none",
                "display": "flex",
                "justify-content": "center",
                "flex-wrap": "wrap",
                "padding": "0",
                "li": {
                  "padding": "0 1rem 1rem 1rem",
                  "p": {
                    "margin": "0"
                  }
                },
                "margin-bottom": "0"
              },
              ".social-list": {
                "padding-left": "0",
                "margin-bottom": "0",
                "list-style": "none",
                "display": "flex",
                "flex-wrap": "wrap",
                "justify-content": "flex-end",
                "-webkit-justify-content": "flex-end",
                ".mbr-iconfont-social": {
                  "font-size": "1.5rem",
                  "color": "#ffffff"
                },
                ".soc-item": {
                  "margin": "0 .5rem"
                },
                "a": {
                  "margin": "0",
                  "opacity": ".5",
                  "-webkit-transition": ".2s linear",
                  "transition": ".2s linear",
                  "&:hover": {
                    "opacity": "1"
                  }
                },
                "@media (max-width: 767px)": {
                  "justify-content": "center",
                  "-webkit-justify-content": "center"
                }
              },
              ".row-copirayt": {
                "word-break": "break-word",
                "width": "100%",
                "p": {
                  "width": "100%"
                }
              }
            }
          },
          "_name": "footer7",
          "_customHTML": "<section group=\"Footers\" global once mbr-class=\"{'mbr-reveal': reveal, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"1\">\n        <input type=\"range\" inline title=\"Menu Items\" name=\"menuItems\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <input type=\"range\" inline title=\"Social Items\" name=\"socialItems\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reveal effect\" name=\"reveal\">\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Background Image\" value=\"../_images/jumbotron.jpg\">\n            <input type=\"color\" title=\"Background Color\" value=\"#2e2e2e\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#3C3C3C\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"container\">\n        <div class=\"media-container-row align-center mbr-white\">\n            <div class=\"row row-links\" mbr-if=\"menuItems > 0\">\n                <ul class=\"foot-menu\" mbr-list mbr-list-grow=\"menuItems\">\n                    <li mbr-text class=\"foot-menu-item mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\"foot-menu-item\">\n                        <a class=\"text-white mbr-bold\" href=\"#\" target=\"_blank\">About us</a>\n                    </li>\n                    \n                    \n                    \n                    \n                </ul>\n            </div>\n            <div class=\"row social-row\" mbr-if=\"socialItems > 0\">\n                <div mbr-list mbr-list-grow=\"socialItems\" class=\"social-list align-right pb-2\">\n                    <div class=\"soc-item\">\n                        <a href=\"https://es-la.facebook.com/scinevivo/\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-facebook socicon\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\">\n                        <a href=\"https://vimeo.com/scinevivo\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-vimeo socicon\"></span>\n                        </a>\n                    </div>\n                    \n                    \n                    \n                    \n                <div class=\"soc-item\">\n                        <a href=\"https://www.youtube.com/channel/UClOG8lF04BgtuWx9SpcB32w\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-youtube socicon\"></span>\n                        </a>\n                    </div><div class=\"soc-item\">\n                        <a href=\"https://www.instagram.com/scinevivo\" target=\"_blank\">\n                            <span mbr-icon class=\"mbr-iconfont mbr-iconfont-social socicon-instagram socicon\"></span>\n                        </a>\n                    </div><div class=\"soc-item\">\n                        <a href=\"mailto:scinevivo@gmail.com\">\n                            <span mbr-icon class=\"mbr-iconfont mbr-iconfont-social mbri-letter\"></span>\n                        </a>\n                    </div></div>\n            </div>\n            <div class=\"row row-copirayt\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style mbr-white align-center\" mbr-theme-style=\"display-7\" data-app-selector=\".media-container-row .mbr-text\">\n                    © Semillero CINEVIVO. Medellín, Colombia. 2018<br>Facultad de Artes y Humanidades. <a href=\"http://www.itm.edu.co\" class=\"text-warning\">Instituto Tecnológico Metropolitano.</a></p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "r13WsQmQ3L",
          "_anchor": "footer7-3n",
          "_protectedParams": [],
          "_global": true,
          "_once": true,
          "_params": {}
        },
        {
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            ".mbr-text, blockquote": {
              "color": "#767676"
            }
          },
          "_name": "content1",
          "_customHTML": "<section class=\"mbr-section article content1\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"4\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"4\">\n        <input type=\"color\" title=\"Background Color\" name=\"bgColor\" value=\"#ffffff\">\n    <!-- End block parameters -->\n    </mbr-parameters> \n\n    <div class=\"container\">\n        <div class=\"media-container-row\">\n            <div class=\"mbr-text col-12 col-md-8 mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" data-multiline mbr-article><b>CICLUX, &nbsp;</b>&nbsp;Fue la propuesta realizada por el Laboratorio de Creación Audiovisual Experimental L.Igth.VE Cinema, &nbsp;conformado por estudiantes de las facultades de artes visuales, Univerisdad de Antioquia  y el Instituto Tecnológico Metropolitano, y  dirigido por el profesor Luis Angel Castro.<div><span style=\"font-size: 1rem;\"><br></span></div><div><span style=\"font-size: 1rem;\">Este grupo se propuso generar una sesión de live cinema a través del manejo de  software específico, en tiempo real, con imágenes y audio creadas y producidas por los mismos estudiantes y con el apoyo logístico de los programas de Artes visuales e informática Musical del ITM, en una puesta en escena con una duración de 23 minutos.&nbsp;</span></div><div><span style=\"font-size: 1rem;\"><br></span></div><div><span style=\"font-size: 1rem;\">Sitio del proyecto: http://festivalfotosintesis.wixsite.com/inicio</span></div><div><span style=\"font-size: 1rem;\">\n</span><span style=\"font-size: 1rem;\">CICLUX* en Youtube</span></div><div><span style=\"font-size: 1rem;\">CICLUX* en FaceBook</span></div><div><br></div><div><span style=\"font-size: 1rem;\">Dirección:Christopher Thomas Allen\n</span></div><div><span style=\"font-size: 1rem;\">Leading Artists:Christopher Thomas Allen &amp; Tim Cowie&nbsp;</span></div><div><span style=\"font-size: 1rem;\">Camera: Christopher Thomas Allen, Tim Cowie, Fauzi Yusoff &amp; Fariz Hanapiah\n</span></div><div><span style=\"font-size: 1rem;\">Editing &amp; Post-Production: Christopher Thomas Allen, Tim Cowie, Fauzi Yusoff, Fariz Hanapiah, Jai Rafferty &amp; Helen Omand\n</span></div><div><span style=\"font-size: 1rem;\">Production Assistants:Jake Dowling &amp; Simon Bertheux\n</span></div><div><span style=\"font-size: 1rem;\">Research Assistant:Annie Kwan\n</span></div><div><span style=\"font-size: 1rem;\">DIrección Musical: Ales Osorio, Felipe González&nbsp;</span></div><div><span style=\"font-size: 1rem;\">Sound Engineering:Shugar Studios\n</span></div><div><span style=\"font-size: 1rem;\">Music Producer:Hardesh Singh\n</span></div><div><span style=\"font-size: 1rem;\">Online Content Manager:Matt Armitage\n</span></div><div><span style=\"font-size: 1rem;\">Diseño y Publicidad:Tan Ee Lyn\n</span></div><div><span style=\"font-size: 1rem;\">\n</span></div><div><span style=\"font-size: 1rem;\">Presentaciones:</span></div><div><span style=\"font-size: 1rem;\">\nCentro Cultural Facultad de artes. Universidad de Antioquia 11/2015</span></div><div><span style=\"font-size: 1rem;\">Auditorio Politecnico Jaime Isaza Cadavid&nbsp;</span></div><div><span style=\"font-size: 1rem;\">Auditorio Menor ITM sede Fraternidad</span></div><div><span style=\"font-size: 1rem;\"><br></span></div></div>\n        </div>\n    </div>\n</section>",
          "_cid": "r13WsRttGW",
          "_anchor": "content1-3o",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        }
      ]
    },
    "obra_CBR.html": {
      "settings": {
        "meta_descr": "Corpus Random Binary\nObra Cinema Expnadido Semillero CINEVIVO. ",
